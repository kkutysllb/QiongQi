{
  "name": "qiongqi-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Qiongqi — 独立多 Agent 框架，骨架不变，血肉万变",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:clean": "node scripts/build.mjs --clean",
    "test": "vitest run",
    "test:unit": "vitest run tests/cache.test.ts tests/contracts.test.ts tests/domain.test.ts tests/ports.test.ts",
    "test:fast": "vitest run --exclude '**/builtin-tools.test.ts'",
    "typecheck": "pnpm -r run typecheck",
    "prepare:sqlite": "node scripts/prepare-sqlite.mjs",
    "verify:sqlite": "pnpm --filter @qiongqi/adapter-storage exec node ../../../scripts/verify-sqlite.mjs",
    "verify:evented-a2a": "node scripts/verify-evented-a2a.mjs --port-a 0 --port-b 0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "node-gyp": "^11.5.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  }
}
