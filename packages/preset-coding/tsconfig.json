{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@qiongqi/contracts": [
        "../contracts/src"
      ],
      "@qiongqi/domain": [
        "../domain/src"
      ],
      "@qiongqi/ports": [
        "../ports/src"
      ],
      "@qiongqi/cache": [
        "../cache/src"
      ],
      "@qiongqi/loop": [
        "../loop/src"
      ],
      "@qiongqi/services": [
        "../services/src"
      ],
      "@qiongqi/adapter-model": [
        "../adapter-model/src"
      ],
      "@qiongqi/adapter-storage": [
        "../adapter-storage/src"
      ],
      "@qiongqi/adapter-tools": [
        "../adapter-tools/src"
      ],
      "@qiongqi/skills": [
        "../skills/src"
      ],
      "@qiongqi/memory": [
        "../memory/src"
      ],
      "@qiongqi/attachments": [
        "../attachments/src"
      ],
      "@qiongqi/delegation": [
        "../delegation/src"
      ],
      "@qiongqi/http": [
        "../http/src"
      ],
      "@qiongqi/cli": [
        "../cli/src"
      ]
    }
  },
  "include": [
    "src"
  ]
}
