{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@qiongqi/contracts": ["packages/contracts/src"],
      "@qiongqi/domain": ["packages/domain/src"],
      "@qiongqi/ports": ["packages/ports/src"],
      "@qiongqi/cache": ["packages/cache/src"],
      "@qiongqi/loop": ["packages/loop/src"],
      "@qiongqi/services": ["packages/services/src"],
      "@qiongqi/adapter-model": ["packages/adapter-model/src"],
      "@qiongqi/adapter-storage": ["packages/adapter-storage/src"],
      "@qiongqi/adapter-tools": ["packages/adapter-tools/src"],
      "@qiongqi/skills": ["packages/skills/src"],
      "@qiongqi/memory": ["packages/memory/src"],
      "@qiongqi/attachments": ["packages/attachments/src"],
      "@qiongqi/delegation": ["packages/delegation/src"],
      "@qiongqi/http": ["packages/http/src"],
      "@qiongqi/cli": ["packages/cli/src"],
      "@qiongqi/preset-coding": ["packages/preset-coding/src"],
      "@qiongqi/adapter-fs": ["packages/adapter-fs/src"],
      "@qiongqi/tool-infra": ["packages/tool-infra/src"]
    }
  },
  "include": ["tests"],
  "exclude": ["node_modules", "dist", "packages"]
}
